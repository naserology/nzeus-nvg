<resources xmlns:tools="http://schemas.android.com/tools">

    <color name="phosphor">#39FF14</color>
    <color name="phosphor_dim">#1f8c0a</color>
    <color name="bg_black">#000000</color>
    <color name="critical">#FF2A2A</color>

    <style name="Theme.NzeusNvg" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/phosphor</item>
        <item name="colorPrimaryDark">@color/bg_black</item>
        <item name="colorAccent">@color/phosphor</item>
        <item name="android:windowBackground">@color/bg_black</item>
        <item name="android:colorBackground">@color/bg_black</item>
        <item name="android:textColorPrimary">@color/phosphor</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.NzeusNvg.Fullscreen" parent="Theme.NzeusNvg">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="NzeusButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/phosphor</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:background">@drawable/btn_tactical</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="NzeusLabel">
        <item name="android:textColor">@color/phosphor</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:paddingTop">6dp</item>
    </style>

</resources>
